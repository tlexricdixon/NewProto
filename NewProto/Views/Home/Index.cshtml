                        <img src="~/img/DSC_0605.jpg" class="d-block w-100 carousel-image" alt="K-9 Training">
                    </div>
                    <div class="carousel-item">
                        <img src="~/img/DSC_4419.JPG" class="d-block w-100 carousel-image" alt="CSI Documenting Car Window with Photo">
                    </div>
                    <div class="carousel-item">
                        <img src="~/img/DSC_5012A.jpg" class="d-block w-100 carousel-image" alt="ISP Flag Waving in Breeze">
                    </div>
                    <div class="carousel-item">
                        <img src="~/img/forensic lab gun testing.jpg" class="d-block w-100 carousel-image" alt="Trooper with Megaphone">
                    </div>
                    <div class="carousel-item">
                        <img src="~/img/IMG_1726.jpg" class="d-block w-100 carousel-image" alt="Gun Range Training">
